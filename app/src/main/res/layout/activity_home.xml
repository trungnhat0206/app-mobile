<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="4dp"
    tools:context=".HomeActivity">

    <!-- PHẦN 1: TextView nằm ở trên cùng (alignParentTop) -->
    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_alignParentTop="true"
        android:background="#EFEF97"
        android:gravity="center"
        android:text="HOME PAGE"
        android:textColor="#000000"
        android:textSize="20sp"
        android:layout_margin="2dp"/>

    <!-- PHẦN 2: Action Bar nằm dưới Header (layout_below) -->
    <RelativeLayout
        android:id="@+id/actionRow"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_below="@id/tvHeader"
        android:layout_marginTop="2dp">

        <View
            android:id="@+id/viewGreen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toLeftOf="@+id/btnLogout"
            android:background="#C8E6C9"
            android:layout_margin="2dp"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="100dp"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true"
            android:text="Logout"
            android:textAllCaps="false"
            android:layout_margin="2dp"/>
    </RelativeLayout>

    <!-- PHẦN 3: Lưới các Button nằm dưới Action Bar (layout_below) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/actionRow"
        android:layout_marginTop="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hàng 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="100dp" android:orientation="horizontal">
                <!-- Nút PAGE chuyển sang trang Main -->
                <Button
                    android:id="@+id/btnPage"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="PAGE"
                    android:layout_margin="2dp"
                    android:textAllCaps="false"
                    android:backgroundTint="#BBDEFB"
                    android:textColor="#000000"/>
                <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Button" android:layout_margin="2dp" android:textAllCaps="false"/>
                <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Button" android:layout_margin="2dp" android:textAllCaps="false"/>
                <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Button" android:layout_margin="2dp" android:textAllCaps="false"/>
            </LinearLayout>

            <!-- Hàng 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="100dp" android:orientation="horizontal" android:layout_marginTop="4dp">
                <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Button" android:layout_margin="2dp" android:textAllCaps="false"/>
                <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Button" android:layout_margin="2dp" android:textAllCaps="false"/>
                <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Button" android:layout_margin="2dp" android:textAllCaps="false"/>
                <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Button" android:layout_margin="2dp" android:textAllCaps="false"/>
            </LinearLayout>

            <!-- Hàng 3 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="100dp" android:orientation="horizontal" android:layout_marginTop="4dp">
                <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Button" android:layout_margin="2dp" android:textAllCaps="false"/>
                <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Button" android:layout_margin="2dp" android:textAllCaps="false"/>
                <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Button" android:layout_margin="2dp" android:textAllCaps="false"/>
                <Button android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Button" android:layout_margin="2dp" android:textAllCaps="false"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>